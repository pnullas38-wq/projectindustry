{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "framework": "fastapi",
      "maxDuration": 60
    }
  },
  "build": {
    "env": {
      "BACKEND_ROUTE_PREFIX": "/_/backend",
      "API_V1_PREFIX": "/_/backend/api/v1",
      "VITE_API_URL": "/_/backend/api/v1"
    }
  }
}
